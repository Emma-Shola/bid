  return `
You are optimizing a single resume bullet point.

STRICT RULES:
- Keep ALL original meaning
- Do NOT remove any detail
- Do NOT shorten
- Do NOT generalize
- Only rephrase and enhance clarity
- You may add relevant keywords from job description

Return ONLY the improved bullet.

ORIGINAL BULLET:
${input.bullet}

JOB DESCRIPTION:
${input.jobDescription}
`;
}
Code flow
for (const section of parsed.sections) {
  for (const item of section.items) {
    item.bullets = await Promise.all(
      item.bullets.map(async (bullet) => {
        return rewriteBullet(bullet);
      })
    );
  }
}

👉 This is now safe transformation, not generative chaos.

🛡️ Step 3: Validation Layer (This is your safety net)

Now compare:

Checks to run:
Same number of sections ✅
Same number of items per section ✅
Same number of bullets ✅
No empty strings ✅
No drastic length reduction (e.g. <70% original length) ❌
Example validator
function validate(original, updated) {
  if (original.sections.length !== updated.sections.length) {
    return false;
  }

  for (let i = 0; i < original.sections.length; i++) {
    const oSec = original.sections[i];
    const uSec = updated.sections[i];

    if (oSec.items.length !== uSec.items.length) return false;

    for (let j = 0; j < oSec.items.length; j++) {
      const oItem = oSec.items[j];
      const uItem = uSec.items[j];

      if (oItem.bullets.length !== uItem.bullets.length) return false;

      for (let k = 0; k < oItem.bullets.length; k++) {
        const oBullet = oItem.bullets[k];
        const uBullet = uItem.bullets[k];

        if (!uBullet || uBullet.length < oBullet.length * 0.7) {
          return false;
        }
      }
    }
  }

  return true;
}
🔁 Recovery Strategy (this is the secret sauce)

If validation fails:

👉 Retry ONLY failed bullets with a stricter prompt:

You removed or lost information. Rewrite again while preserving every detail exactly.

Worst case fallback:
👉 Use original bullet (never lose data)

🧱 Step 4 (Optional but Elite): Rebuild Resume

Now convert JSON → Markdown:

function rebuildResume(structured) {
  return structured.sections
    .map(section => {
      return `## ${section.name}\n\n` +
        section.items.map(item => `
**${item.title}** — ${item.company} (${item.date})
${item.bullets.map(b => `- ${b}`).join("\n")}
`).join("\n");
    })
    .join("\n\n");
}
⚡ Why this pipeline is superior
Old Approach	New Approach
One big prompt	Controlled micro-edits
High hallucination risk	Near-zero data loss
Hard to debug	Fully traceable
Silent errors	Detectable + fixable
